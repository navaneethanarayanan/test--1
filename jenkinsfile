pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/navaneethanarayanan/test--1.git'
            }
        }

         stage('Build') {
            steps {
                sh 'echo Building the project...'
                sh 'ls -la'
            }
        }

        stage('tests') {
             steps{
                sh'echo Running tests...'
                
            }
        }

        stage('Publish HTML') {
            steps {
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: '.',
                    reportFiles: 'hello.html',
                    reportName: 'My Website'
                ])
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'hello.html'
            }
        }
    }
}