pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/navaneethanarayanan/test--1.git'
            }
        }

        stage('Debug') {
            steps {
                sh '''
                pwd
                ls -la
                cat index.html
                '''
            }
        }

        stage('Publish HTML') {
            steps {
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: '.',
                    reportFiles: 'index.html',
                    reportName: 'My Website'
                ])
            }
        }
    }
}